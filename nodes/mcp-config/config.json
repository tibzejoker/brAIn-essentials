{
  "name": "mcp-config",
  "description": "Manager of MCP servers. Owns a single global JSON of {mcpServers: {...}} and reconciles by spawning / killing mcp-server children — one node per entry. The de-facto config shape is the same one Claude Desktop / Cursor / Cline use, so the same JSON works across clients. Validation is enforced before save (no partial writes). Kill this node and all its children stop.",
  "tags": [
    "service",
    "mcp",
    "manager"
  ],
  "default_authority": 1,
  "default_priority": 3,
  "ports": {
    "inputs": {
      "mcp.config.reload": {
        "description": "Re-read this manager's mcpServers config and reconcile children.",
        "inputSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      },
      "mcp.config.tools.request": {
        "description": "Request the aggregated catalog of all tools across child mcp-server nodes. Reply on mcp.config.tools.",
        "inputSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      },
      "mcp.config.call": {
        "description": "Call any aggregated tool by qualified name. Payload: {tool: \"<alias>__<name>\", args: {...}, reply_to?: \"<topic>\"}.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "tool": {
              "type": "string",
              "description": "Qualified name like 'notion__notion-search'"
            },
            "args": {
              "type": "object"
            },
            "reply_to": {
              "type": "string"
            }
          },
          "required": [
            "tool"
          ]
        }
      },
      "mcp.config.set": {
        "description": "Replace the global mcpServers config and reconcile. Payload: {mcpServers: {...}}.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "mcpServers": {
              "type": "object"
            }
          },
          "required": [
            "mcpServers"
          ]
        }
      }
    },
    "outputs": {
      "mcp.config.status": {
        "description": "mcp.config.status"
      },
      "mcp.config.tools": {
        "description": "mcp.config.tools"
      },
      "mcp.config.call.result": {
        "description": "mcp.config.call.result"
      }
    }
  },
  "default_port_bindings": {
    "inputs": {
      "mcp.config.reload": [
        "mcp.config.reload"
      ],
      "mcp.config.tools.request": [
        "mcp.config.tools.request"
      ],
      "mcp.config.call": [
        "mcp.config.call"
      ],
      "mcp.config.set": [
        "mcp.config.set"
      ]
    },
    "outputs": {
      "mcp.config.status": [
        "mcp.config.status"
      ],
      "mcp.config.tools": [
        "mcp.config.tools"
      ],
      "mcp.config.call.result": [
        "mcp.config.call.result"
      ]
    }
  },
  "has_ui": true,
  "supports_transport": [
    "process"
  ]
}
