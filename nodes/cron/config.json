{
  "name": "cron",
  "description": "Publishes a configurable message at a configurable interval. Set topic, content, criticality, and interval via config_overrides.",
  "tags": [
    "utility",
    "scheduler"
  ],
  "default_authority": 0,
  "default_priority": 1,
  "ports": {
    "outputs": {
      "cron.tick": {
        "description": "cron.tick"
      }
    }
  },
  "default_port_bindings": {
    "outputs": {
      "cron.tick": [
        "cron.tick"
      ]
    }
  },
  "interval": "10s",
  "supports_transport": [
    "process"
  ]
}
